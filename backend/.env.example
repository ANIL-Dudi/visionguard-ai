# Copy to .env and adjust as needed. All values have sensible defaults
# in app/config.py if this file is absent.

# Path to your fine-tuned weights (auto-detected if present)
VG_CUSTOM_WEIGHTS=weights/helmet_triple_yolov8.pt

# Stock model used until custom weights exist
VG_FALLBACK_WEIGHTS=yolov8n.pt

# Minimum confidence for a detection to be considered at all
VG_CONF_THRESH=0.35
